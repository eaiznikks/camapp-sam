<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_screen"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_eyebrow"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="@string/hero_badge"
                android:textAllCaps="true"
                android:textColor="@color/ink_primary"
                android:textSize="11sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="-0.02"
                android:lineSpacingExtra="2dp"
                android:text="@string/hero_title"
                android:textColor="@color/ink_primary"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:alpha="0.88"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="3dp"
                android:text="@string/hero_subtitle"
                android:textColor="@color/ink_secondary"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_panel_card"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_section_chip"
                    android:fontFamily="sans-serif-medium"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="@string/preview_chip"
                    android:textAllCaps="true"
                    android:textColor="@color/ink_primary"
                    android:textSize="10sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_preview_shell"
                    android:padding="3dp">

                    <FrameLayout
                        android:id="@+id/previewContainer"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/preview_black" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:layout_margin="14dp"
                        android:background="@drawable/bg_overlay_label"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_live_dot" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/live_preview"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_panel_card"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_section_chip"
                    android:fontFamily="sans-serif-medium"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="@string/status_chip"
                    android:textAllCaps="true"
                    android:textColor="@color/ink_primary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/starting_camera"
                    android:textColor="@color/ink_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/serverStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_status_neutral"
                    android:fontFamily="sans-serif-medium"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:text="@string/server_idle"
                    android:textColor="@color/ink_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/ipAddressText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_url_card"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp"
                    android:padding="16dp"
                    android:text="@string/ip_detecting"
                    android:textColor="@color/ink_primary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:alpha="0.9"
                    android:fontFamily="sans-serif"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/url_helper"
                    android:textColor="@color/ink_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <Button
                android:id="@+id/captureButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_capture_button"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="20dp"
                android:paddingVertical="18dp"
                android:text="@string/capture_button"
                android:textAllCaps="false"
                android:textColor="@color/button_text"
                android:textSize="18sp" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
