<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="@color/screen_bottom"
                android:startColor="@color/screen_top" />
        </shape>
    </item>
    <item android:gravity="top|end" android:right="-48dp" android:top="-56dp">
        <shape android:shape="oval">
            <size
                android:width="220dp"
                android:height="220dp" />
            <solid android:color="@color/glow_gold" />
        </shape>
    </item>
    <item android:gravity="bottom|start" android:bottom="-80dp" android:left="-60dp">
        <shape android:shape="oval">
            <size
                android:width="260dp"
                android:height="260dp" />
            <solid android:color="@color/glow_blue" />
        </shape>
    </item>
</layer-list>
